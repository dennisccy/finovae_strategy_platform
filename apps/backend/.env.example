# Finovae Strategy API — Environment Variables

# OpenAI API Key (REQUIRED — default model is gpt-5.4-mini; model list lives in
# apps/backend/shared/model_catalog.py, served by GET /api/models)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API Key (optional — only needed if you select a Claude model)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Directory for caching market data as a single Parquet file per (symbol, timeframe).
# Leave unset to use the durable in-repo default (<repo>/.data/market_data) —
# never use a volatile /tmp path (cache would be lost on reboot / tmp clear).
# If you override, use an ABSOLUTE path (a relative value resolves against CWD).
# MARKET_DATA_CACHE_DIR=/absolute/path/to/market_data

# Server configuration
HOST=0.0.0.0
PORT=8000

# CORS origins (comma-separated URLs for allowed frontend origins)
# Example: https://your-frontend.vercel.app,http://localhost:5173
CORS_ORIGINS=

# Development mode
DEBUG=false

# Directory for storing backtest session data (file-based persistence).
# Leave unset to use the durable in-repo default (<repo>/.data/backtests) —
# never use a volatile /tmp path (session/run history must survive a restart).
# If you override, use an ABSOLUTE path (a relative value resolves against CWD).
# BACKTEST_STORE_DIR=/absolute/path/to/backtests

# Number of uvicorn workers. Set this to match --workers N in your uvicorn start command.
# Each worker process handles one backtest at a time; total capacity = WEB_CONCURRENCY.
# Example: WEB_CONCURRENCY=4 uvicorn backend.api:app --workers 4
WEB_CONCURRENCY=1